# Copy this file to `backend/.env.local` and fill in the values.
# The backend reads these at startup — restart the server after editing.
#
# WARNING: .env.local is gitignored. Never commit API keys.

# ── Required ────────────────────────────────────────────────────────────────

# OpenAI API key — used for the attending grader, triage classifier, and
# realtime voice token minting. Never exposed to the browser.
OPENAI_API_KEY=

# Attending grader agent ID (cached; set automatically on first /agent/bootstrap).
ATRIUM_AGENT_ID=

# ── OpenAI Realtime (voice) ──────────────────────────────────────────────────

# Realtime model for patient voice. The server probes the live model list and
# falls back to this value if the probe fails.
# Valid options: gpt-4o-mini-realtime-preview, gpt-4o-realtime-preview
OPENAI_REALTIME_MODEL=gpt-4o-mini-realtime-preview

# Gender-specific voice IDs for the patient realtime voice agent.
# Male patients use OPENAI_REALTIME_MALE_VOICE; female patients (and pediatric
# cases where the parent is female) use OPENAI_REALTIME_FEMALE_VOICE.
# Must be valid OpenAI Realtime voice IDs.
OPENAI_REALTIME_MALE_VOICE=ballad
OPENAI_REALTIME_FEMALE_VOICE=shimmer

# ── Optional overrides ───────────────────────────────────────────────────────

# Override the attending grader chat completion model (default: gpt-4o).
# OPENAI_AGENT_MODEL=gpt-4o

# Override the ER triage classifier model (default: gpt-4o-mini).
# OPENAI_TRIAGE_MODEL=gpt-4o-mini

# Shared secret between the Vercel edge middleware and this backend.
# Required in production — Vercel injects this header; the backend checks it.
# Localhost requests bypass auth automatically; this var can be omitted for dev.
# BACKEND_SHARED_SECRET=

# Hospital EHR credential vault token. Set to enable the
# POST /agent/vault/ehr/lookup endpoint used by the attending grader.
# The token is never logged or returned to clients.
# EHR_API_TOKEN=
